// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientLinks Client[] @relation("ClientUserLink")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrgRole {
  OWNER
  TRAINER
  STAFF
  CLIENT
}

model Membership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, role])
  @@index([orgId])
  @@index([userId])
}

model Client {
  id        String   @id @default(cuid())
  orgId     String

  // optional: link to a login account later
  userId    String?  @unique

  name      String
  notes     String?
  archived  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user  User?        @relation("ClientUserLink", fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([archived])
}