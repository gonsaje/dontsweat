// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  clientLinks Client[] @relation("ClientUserLink")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  clients     Client[]
  templates   SessionTemplate[]
  sessions    SessionInstance[]
}

enum OrgRole {
  OWNER
  TRAINER
  STAFF
  CLIENT
}

model Membership {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  role      OrgRole
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, role])
  @@index([orgId])
  @@index([userId])
}

model Client {
  id        String   @id @default(uuid())
  orgId     String

  // optional: link to a login account later
  userId    String?

  name      String
  notes     String?
  archived  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User?              @relation("ClientUserLink", fields: [userId], references: [id], onDelete: SetNull)
  sessions SessionInstance[]
  
  @@unique([orgId, userId])
  @@index([orgId])
  @@index([archived])
}

model SessionTemplate {
  id        String   @id @default(uuid())
  orgId     String
  title     String
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  exercises TemplateExercise[]
  sessions  SessionInstance[]

  @@index([orgId])
}

model TemplateExercise {
  id         String @id @default(uuid())
  templateId String

  name       String
  sets       Int?
  reps       Int?
  notes      String?
  sortOrder  Int    @default(0)

  template   SessionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model SessionInstance {
  id           String   @id @default(uuid())
  orgId        String
  clientId     String
  templateId   String?

  scheduledFor DateTime
  completedAt  DateTime?
  coachNotes   String?

  shareToken   String?  @unique

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template SessionTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  exercises SessionExercise[]

  @@index([orgId])
  @@index([clientId])
  @@index([scheduledFor])
}

model SessionExercise {
  id           String @id @default(uuid())
  sessionId    String

  name         String
  setsPlanned  Int?
  repsPlanned  Int?
  notesPlanned String?

  weightUsed   Float?
  setsDone     Int?
  repsDone     Int?
  notesResult  String?

  sortOrder    Int    @default(0)

  session      SessionInstance @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
